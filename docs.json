{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "HaiPay",
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "languages": [
      {
        "language": "zh",
        "navbar": {
          "links": [
            { "label": "支持", "href": "https://your-support-url.com" }
          ],
          "primary": {
            "type": "button",
            "label": "控制台",
            "href": "https://your-dashboard-url.com"
          }
        },
        "footer": {
          "socials": {
            "x": "https://x.com/mintlify",
            "github": "https://github.com/mintlify"
          }
        },
        "tabs": [
          {
            "tab": "文档中心",
            "groups": [
              {
                "group": "商户指南",
                "pages": [
                  "docs/zh/guide/api_description_guide",
                  "docs/zh/guide/api_doc_list",
                  "docs/zh/guide/api_parameters_doc",
                  "docs/zh/guide/config_settings_and_signature_rules_guide",
                  "docs/zh/guide/end_to_end_testing",
                  "docs/zh/guide/error_response_appendix",
                  "docs/zh/guide/frequently_asked_question",
                  "docs/zh/guide/integration_guide",
                  "docs/zh/guide/integration_process_guide",
                  "docs/zh/guide/onboarding_checklist",
                  "docs/zh/guide/phone_regex"
                ]
              }
            ]
          },
          {
            "tab": "API reference",
            "openapi": "openapi.json",
            "pages": [
              "POST /global/cashier/collect/apply"
            ]
          }
        ]
      },
      {
        "language": "en",
        "navbar": {
          "links": [
            { "label": "Support", "href": "https://your-support-url.com" }
          ],
          "primary": {
            "type": "button",
            "label": "Dashboard",
            "href": "https://your-dashboard-url.com"
          }
        },
        "footer": {
          "socials": {
            "x": "https://x.com/mintlify",
            "github": "https://github.com/mintlify"
          }
        },
        "groups": [
          {
            "group": "Comenzando",
            "pages": ["index", "quickstart"]
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "支持",
        "href": "https://your-dashboard-url.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "控制台",
      "href": "https://your-dashboard-url.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  },
  "api": {
    "playground": {
      "display": "interactive",
      "proxy": true
    }
  }
}
