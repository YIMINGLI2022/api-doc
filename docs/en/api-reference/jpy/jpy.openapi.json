{
  "openapi": "3.0.1",
  "info": {
    "title": "默认模块",
    "description": "",
    "version": "1.0.0"
  },
  "tags": [],
  "paths": {
    "/jpy/collect/apply": {
      "post": {
        "summary": "JPY Collection Application",
        "deprecated": false,
        "description": "appId需使用日圆对应的，用户支付成功后增加日圆余额",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "appId": {
                    "type": "integer",
                    "description": "Business ID (obtained from backend, must pass corresponding business ID based on currency in URL)"
                  },
                  "orderId": {
                    "type": "string",
                    "description": "Merchant order number",
                    "maxLength": 48
                  },
                  "name": {
                    "type": "string",
                    "description": "Recipient name"
                  },
                  "phone": {
                    "type": "string",
                    "description": "Real phone number"
                  },
                  "email": {
                    "type": "string",
                    "description": "Real email address",
                    "format": "email"
                  },
                  "amount": {
                    "type": "string",
                    "description": "Transaction amount (no decimal places allowed)",
                    "pattern": "^\\d+$"
                  },
                  "payType": {
                    "type": "string",
                    "description": ""
                  },
                  "inBankCode": {
                    "type": "string",
                    "description": ""
                  },
                  "callBackUrl": {
                    "type": "string",
                    "description": "URL to redirect after successful payment",
                    "format": "uri"
                  },
                  "callBackFailUrl": {
                    "type": "string",
                    "description": "URL to redirect after failed payment",
                    "format": "uri"
                  },
                  "notifyUrl": {
                    "type": "string",
                    "description": "Callback URL",
                    "format": "uri"
                  },
                  "subject": {
                    "type": "string",
                    "description": "Payment remark"
                  },
                  "body": {
                    "type": "string",
                    "description": "Remark details"
                  },
                  "partnerUserId": {
                    "type": "string",
                    "description": "Unique user identifier (e.g., userId), used for risk control, must be real and valid, otherwise it will affect transactions. Format requirements: digits, uppercase and lowercase letters or common symbols -~!@#$%&*()_.",
                    "pattern": "^[A-Za-z0-9\\-~!@#$%&*()_]+$"
                  },
                  "sign": {
                    "type": "string",
                    "description": "Signature"
                  }
                },
                "required": [
                  "appId",
                  "orderId",
                  "name",
                  "phone",
                  "email",
                  "amount",
                  "payType",
                  "inBankCode",
                  "callBackUrl",
                  "callBackFailUrl",
                  "partnerUserId",
                  "sign"
                ],
                "additionalProperties": false
              },
              "examples": {}
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "1: Normal, 0: Exception"
                    },
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "msg": {
                      "type": "string",
                      "description": "Error description"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "Merchant order number (must be unique)"
                        },
                        "orderNo": {
                          "type": "string",
                          "description": "Platform order number"
                        },
                        "payUrl": {
                          "type": "string",
                          "description": "Payment link"
                        },
                        "sign": {
                          "type": "string",
                          "description": "Signature"
                        }
                      },
                      "additionalProperties": false,
                      "description": ""
                    }
                  },
                  "additionalProperties": false
                }
              }
            }
          }
        },
        "security": []
      }
    },
    "/jpy/collect/query": {
      "post": {
        "summary": "JPY Collection Query",
        "deprecated": false,
        "description": "查询代收订单",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "appId": {
                    "type": "integer",
                    "description": "Business ID (obtained from backend, must pass corresponding business ID based on currency in URL)"
                  },
                  "orderId": {
                    "type": "string",
                    "description": "Merchant order number"
                  },
                  "orderNo": {
                    "type": "string",
                    "description": "Platform order number (faster response)"
                  },
                  "sign": {
                    "type": "string",
                    "description": "Signature"
                  }
                },
                "required": [
                  "appId",
                  "orderId",
                  "sign"
                ]
              },
              "examples": {}
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "1: Normal, 0: Exception"
                    },
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "msg": {
                      "type": "string",
                      "description": "Error description"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "Merchant order number (must be unique)"
                        },
                        "orderNo": {
                          "type": "string",
                          "description": "Platform order number"
                        },
                        "amount": {
                          "type": "string",
                          "description": "Transaction amount"
                        },
                        "actualAmount": {
                          "type": "string",
                          "description": "Amount received"
                        },
                        "fee": {
                          "type": "string",
                          "description": "Handling fee"
                        },
                        "status": {
                          "type": "integer",
                          "description": "Status (0 - Not started, 1 - In progress, 2 - Success (final), 3 - Failure (final), -1 - Pending confirmation)"
                        },
                        "payTime": {
                          "type": "string",
                          "description": "Payment success time (present when status=2) (Japan time), format: yyyy-MM-dd HH:mm:ss"
                        },
                        "errorMsg": {
                          "type": "string",
                          "description": "Failure reason (present when status=3)"
                        },
                        "sign": {
                          "type": "string",
                          "description": "Signature"
                        }
                      },
                      "additionalProperties": false,
                      "default": {}
                    }
                  },
                  "additionalProperties": false
                }
              }
            }
          }
        },
        "security": []
      }
    }
  },
  "components": {
    "schemas": {},
    "responses": {},
    "securitySchemes": {}
  },
  "servers": [
    {
      "url": "https://uat-interface.haipay.asia",
      "description": "测试-interface"
    }
  ],
  "security": []
}