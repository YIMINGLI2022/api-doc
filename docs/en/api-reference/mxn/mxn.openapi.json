                        "sign": ""
                      }
                    }
                  },
                  "2": {
                    "summary": "订单成功",
                    "value": {
                      "status": "1",
                      "error": "00000000",
                      "msg": "",
                      "data": {
                        "orderId": "M1234567112",
                        "orderNo": "3022111517401574",
                        "amount": "100000.00",
                        "fee": "1003.00",
                        "status": 2,
                        "payTime": "2024-03-01 23:59:59",
                        "sign": ""
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "security": []
      }
    }
