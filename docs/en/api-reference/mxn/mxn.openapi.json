                        },
                        "orderNo": {
                          "type": "string",
                          "description": "Platform Order Number"
                        },
                        "amount": {
                          "type": "string",
                          "description": "Transaction Amount"
                        },
                        "fee": {
                          "type": "string",
                          "description": "Transaction Fee"
                        },
                        "status": {
                          "type": "integer",
                          "description": "Order Status (0 Not Started, 1 Processing, 2 Success (final), 3 Failed (final), -1 Exception Pending Confirmation)",
                          "enum": [
                            0,
                            1,
                            2,
                            3,
                            -1
                          ]
                        },
                        "payTime": {
                          "type": "string",
                          "description": "Payment Success Time (available when status=2) (Mexico Time), format: yyyy-MM-dd HH:mm:ss",
                          "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$"
                        },
                        "errorMsg": {
