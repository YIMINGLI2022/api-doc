{
  "openapi": "3.0.1",
  "info": {
    "title": "默认模块",
    "description": "",
    "version": "1.0.0"
  },
  "tags": [],
  "paths": {
    "/usd/pay/apply": {
      "post": {
        "summary": "PayPal Disbursement Application",
        "deprecated": false,
        "description": "",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "appId": {
                    "type": "integer",
                    "description": "业务ID（后台获取，需要根据URL中的币种传递对应的业务ID）"
                  },
                  "orderId": {
                    "type": "string",
                    "description": "商户订单号(必须保证唯一性，长度不超过48)",
                    "maxLength": 48
                  },
                  "name": {
                    "type": "string",
                    "description": "收款人姓名，推荐使用真实姓名，必须英文，不带特殊字符，以空格分割的，至少包含firstName和lastName，示例：Donald John Trump"
                  },
                  "phone": {
                    "type": "string",
                    "description": "真实手机号（格式参考 电话号码格式 ）"
                  },
                  "email": {
                    "type": "string",
                    "description": "真实电子邮件",
                    "format": "email"
                  },
                  "notifyUrl": {
                    "type": "string",
                    "description": "回调地址",
                    "format": "uri"
                  },
                  "amount": {
                    "type": "string",
                    "description": "交易金额(单位：美元，精确到小数点后两位；禁止添加标点符号，例如：\",\"）",
                    "pattern": "^\\d+\\.\\d{2}$"
                  },
                  "accountType": {
                    "type": "string",
                    "description": "账户类型"
                  },
                  "bankCode": {
                    "type": "string",
                    "description": "支付方式"
                  },
                  "subject": {
                    "type": "string",
                    "description": "支付备注"
                  },
                  "accountNo": {
                    "type": "string",
                    "description": "账号，PayPal的邮箱就是账号"
                  },
                  "identifyType": {
                    "type": "string",
                    "description": "银行路由编码，ACH方式必填"
                  },
                  "body": {
                    "type": "string",
                    "description": "备注详情，ECASHAPP方式必填"
                  },
                  "country": {
                    "type": "string",
                    "description": "收款人所在国家，ACH方式必填，如美国为US"
                  },
                  "address1": {
                    "type": "string",
                    "description": "收款地址-详细街道，ACH方式必填"
                  },
                  "address2": {
                    "type": "string",
                    "description": "收款地址-城市，ACH方式必填"
                  },
                  "address3": {
                    "type": "string",
                    "description": "收款地址(省、州)，ACH方式必填"
                  },
                  "postalCode": {
                    "type": "string",
                    "description": "收款邮编，ACH方式必填"
                  },
                  "bankName": {
                    "type": "string",
                    "description": "银行名称，ACH方式必填"
                  },
                  "swiftCode": {
                    "type": "string",
                    "description": "swiftCode，ACH方式必填"
                  },
                  "partnerUserId": {
                    "type": "string",
                    "description": "用户唯一标识（如用户ID userId），用于风控系统，必须真实有效，否则会影响交易。 格式要求：数字、大小写字母或常用符号-~!@#$%&*()_。",
                    "pattern": "^[A-Za-z0-9\\-~!@#$%&*()_]+$"
                  },
                  "sign": {
                    "type": "string",
                    "description": "签名"
                  }
                },
                "required": [
                  "appId",
                  "orderId",
                  "name",
                  "phone",
                  "email",
                  "amount",
                  "accountType",
                  "bankCode",
                  "subject",
                  "accountNo",
                  "partnerUserId",
                  "sign"
                ]
              },
              "example": {
                "appId": 1054,
                "orderId": "M233323000059",
                "amount": "300",
                "phone": "09230219312",
                "email": "23423@qq.com",
                "name": "test",
                "accountType": "EWALLET",
                "bankCode": "PayPal",
                "accountNo": "123465",
                "partnerUserId": "149597870",
                "sign": "af0gAHkUOyYH***"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "状态码"
                    },
                    "error": {
                      "type": "string",
                      "description": "错误码"
                    },
                    "msg": {
                      "type": "string",
                      "description": "返回信息"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "商户订单号(必须保证唯一性)"
                        },
                        "orderNo": {
                          "type": "string",
                          "description": "平台订单号"
                        },
                        "payUrl": {
                          "type": "string",
                          "description": "支付链接"
                        },
                        "sign": {
                          "type": "string",
                          "description": "签名"
                        }
                      }
                    }
                  }
                },
                "example": {
                  "status": "1",
                  "error": "00000000",
                  "msg": "",
                  "data": {
                    "orderId": "M233323000059",
                    "orderNo": "6023071013539074",
                    "payUrl": "",
                    "sign": "YEoA8Y2JzQFG***"
                  }
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/usd/pay/query": {
      "post": {
        "summary": "PayPal Disbursement Query",
        "deprecated": false,
        "description": "创建代付订单\n\n同步返回orderNo可以直接查询\n\n其他支付方式异步通知后，通过orderNo查询二次确认状态",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "appId": {
                    "type": "integer",
                    "description": "业务ID（后台获取，需要根据URL中的币种传递对应的业务ID）"
                  },
                  "orderId": {
                    "type": "string",
                    "description": "商户订单号"
                  },
                  "orderNo": {
                    "type": "string",
                    "description": "平台订单号（响应快）"
                  },
                  "sign": {
                    "type": "string",
                    "description": "签名"
                  }
                }
              },
              "examples": {}
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "状态码"
                    },
                    "error": {
                      "type": "string",
                      "description": "错误码"
                    },
                    "msg": {
                      "type": "string",
                      "description": "消息"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "商户订单号(必须保证唯一性)"
                        },
                        "orderNo": {
                          "type": "string",
                          "description": "平台订单号"
                        },
                        "amount": {
                          "type": "string",
                          "description": "交易金额"
                        },
                        "fee": {
                          "type": "string",
                          "description": "手续费"
                        },
                        "status": {
                          "type": "integer",
                          "description": "状态(0未开始，1支付中，2成功（终态），3失败（终态）, -1异常待确认)"
                        },
                        "payTime": {
                          "type": "string",
                          "description": "支付成功时间（当status=2时有值）(本地时间), 格式: yyyy-MM-dd HH:mm:ss"
                        },
                        "errorMsg": {
                          "type": "string",
                          "description": "支付失败原因（当status=3时有值）"
                        },
                        "sign": {
                          "type": "string",
                          "description": "签名"
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    }
  },
  "components": {
    "schemas": {},
    "responses": {},
    "securitySchemes": {}
  },
  "servers": [
    {
      "url": "https://uat-interface.haipay.asia",
      "description": "测试-interface"
    }
  ],
  "security": []
}