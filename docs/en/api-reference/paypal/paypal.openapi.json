{
  "openapi": "3.0.1",
  "info": {
    "title": "默认模块",
    "description": "",
    "version": "1.0.0"
  },
  "tags": [],
  "paths": {
    "/usd/pay/apply": {
      "post": {
        "summary": "PayPal Disbursement Application",
        "deprecated": false,
        "description": "",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "appId": {
                    "type": "integer",
                    "description": "Business ID (obtained from the backend; must use the corresponding business ID for the currency in the URL)."
                  },
                  "orderId": {
                    "type": "string",
                    "description": "Merchant order number (must be unique, max length 48).",
                    "maxLength": 48
                  },
                  "name": {
                    "type": "string",
                    "description": "Recipient's full name, recommended to use the real name in English, no special characters, separated by spaces, must include at least firstName and lastName. Example: Donald John Trump"
                  },
                  "phone": {
                    "type": "string",
                    "description": "Real phone number."
                  },
                  "email": {
                    "type": "string",
                    "description": "Real email address.",
                    "format": "email"
                  },
                  "notifyUrl": {
                    "type": "string",
                    "description": "Callback URL.",
                    "format": "uri"
                  },
                  "amount": {
                    "type": "string",
                    "description": "Transaction amount (unit: USD, accurate to two decimals; no punctuation marks allowed, e.g., \",\" ).",
                    "pattern": "^\\d+\\.\\d{2}$"
                  },
                  "accountType": {
                    "type": "string",
                    "description": "Account type."
                  },
                  "bankCode": {
                    "type": "string",
                    "description": "Payment Method."
                  },
                  "subject": {
                    "type": "string",
                    "description": "Payment remark."
                  },
                  "accountNo": {
                    "type": "string",
                    "description": "Account number, for PayPal it is the email address."
                  },
                  "identifyType": {
                    "type": "string",
                    "description": "Bank routing code, required for ACH."
                  },
                  "body": {
                    "type": "string",
                    "description": "Remark details, required for ECASHAPP."
                  },
                  "country": {
                    "type": "string",
                    "description": "Recipient's country, required for ACH, for example: US."
                  },
                  "address1": {
                    "type": "string",
                    "description": "Recipient's address - street details, required for ACH."
                  },
                  "address2": {
                    "type": "string",
                    "description": "Recipient's address - city, required for ACH."
                  },
                  "address3": {
                    "type": "string",
                    "description": "Recipient's address - state/province, required for ACH."
                  },
                  "postalCode": {
                    "type": "string",
                    "description": "Recipient's postal code, required for ACH."
                  },
                  "bankName": {
                    "type": "string",
                    "description": "Recipient's bank name, required for ACH."
                  },
                  "swiftCode": {
                    "type": "string",
                    "description": "swiftCode, required for ACH."
                  },
                  "partnerUserId": {
                    "type": "string",
                    "description": "User unique identifier (e.g., userId). Used for risk control. Must be real and valid, otherwise it will affect the transaction. Allowed characters: digits, uppercase/lowercase letters, or common symbols `-~!@#$%&*()_`.",
                    "pattern": "^[A-Za-z0-9\\-~!@#$%&*()_]+$"
                  },
                  "sign": {
                    "type": "string",
                    "description": "Signature."
                  }
                },
                "required": [
                  "appId",
                  "orderId",
                  "name",
                  "phone",
                  "email",
                  "amount",
                  "accountType",
                  "bankCode",
                  "subject",
                  "accountNo",
                  "partnerUserId",
                  "sign"
                ]
              },
              "example": {
                "appId": 1054,
                "orderId": "M233323000059",
                "amount": "300",
                "phone": "09230219312",
                "email": "23423@qq.com",
                "name": "test",
                "accountType": "EWALLET",
                "bankCode": "PayPal",
                "accountNo": "123465",
                "partnerUserId": "149597870",
                "sign": "af0gAHkUOyYH***"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "1: Normal, 0: Exception"
                    },
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "msg": {
                      "type": "string",
                      "description": "Error description"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "Merchant order number (must be unique)."
                        },
                        "orderNo": {
                          "type": "string",
                          "description": "Platform order number."
                        },
                        "payUrl": {
                          "type": "string",
                          "description": "Payment link."
                        },
                        "sign": {
                          "type": "string",
                          "description": "Signature."
                        }
                      }
                    }
                  }
                },
                "example": {
                  "status": "1",
                  "error": "00000000",
                  "msg": "",
                  "data": {
                    "orderId": "M233323000059",
                    "orderNo": "6023071013539074",
                    "payUrl": "",
                    "sign": "YEoA8Y2JzQFG***"
                  }
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/usd/pay/query": {
      "post": {
        "summary": "PayPal Disbursement Query",
        "deprecated": false,
        "description": "创建代付订单\n\n同步返回orderNo可以直接查询\n\n其他支付方式异步通知后，通过orderNo查询二次确认状态",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "appId": {
                    "type": "integer",
                    "description": "Business ID (obtained from the backend; must match the currency in the URL)."
                  },
                  "orderId": {
                    "type": "string",
                    "description": "Merchant order number."
                  },
                  "orderNo": {
                    "type": "string",
                    "description": "Platform order number (faster response)."
                  },
                  "sign": {
                    "type": "string",
                    "description": "Signature."
                  }
                }
              },
              "examples": {}
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "1: Normal, 0: Exception"
                    },
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "msg": {
                      "type": "string",
                      "description": "Error description"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "Merchant order number (must be unique)."
                        },
                        "orderNo": {
                          "type": "string",
                          "description": "Platform order number."
                        },
                        "amount": {
                          "type": "string",
                          "description": "Transaction amount."
                        },
                        "fee": {
                          "type": "string",
                          "description": "Transaction fee."
                        },
                        "status": {
                          "type": "integer",
                          "description": "Status (0 = Not started, 1 = Processing, 2 = Success (final), 3 = Failed (final), -1 = Exception pending confirmation)."
                        },
                        "payTime": {
                          "type": "string",
                          "description": "Payment success time (value present when status=2). Local time, format: yyyy-MM-dd HH:mm:ss."
                        },
                        "errorMsg": {
                          "type": "string",
                          "description": "Failure reason (value present when status=3)."
                        },
                        "sign": {
                          "type": "string",
                          "description": "Signature."
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    }
  },
  "components": {
    "schemas": {},
    "responses": {},
    "securitySchemes": {}
  },
  "servers": [
    {
      "url": "https://uat-interface.haipay.asia",
      "description": "测试-interface"
    }
  ],
  "security": []
}