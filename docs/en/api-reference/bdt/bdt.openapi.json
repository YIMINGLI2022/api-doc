                        },
                        "status": {
                          "type": "integer",
                          "description": "Status (0 = Not started, 1 = Processing, 2 = Success (final), 3 = Failed (final), -1 = Exception pending confirmation)"
                        },
                        "payTime": {
                          "type": "string",
                          "description": "Payment success time (exists when status=2) (local currency Time UTC+06:00), format: yyyy-MM-dd HH:mm:ss"
