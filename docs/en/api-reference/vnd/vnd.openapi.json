{
  "openapi": "3.0.1",
  "info": {
    "title": "默认模块",
    "description": "",
    "version": "1.0.0"
  },
  "tags": [],
  "paths": {
    "/vnd/collect/apply": {
      "post": {
        "summary": "VND Collection Application",
        "deprecated": false,
        "description": "appId需使用越南盾对应的，用户支付成功后增加越南盾余额",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "appId": {
                    "type": "integer",
                    "description": "Business ID (obtained from backend, must match the currency in the URL)"
                  },
                  "orderId": {
                    "type": "string",
                    "description": "Merchant order ID",
                    "maxLength": 48
                  },
                  "name": {
                    "type": "string",
                    "description": "Payer name (Format: English or Vietnamese case-insensitive, spaces allowed, 1-30 characters, \"firstName middleName lastName\" (middleName is optional). Special characters supported: ! -)",
                    "minLength": 1,
                    "maxLength": 30,
                    "pattern": "^[A-Za-zÀ-ỹ\\s!-]+$"
                  },
                  "outBankNo": {
                    "type": "string",
                    "description": "Payer card number, required when payType = PAYMENT_GATEWAY"
                  },
                  "phone": {
                    "type": "string",
                    "description": "Real phone number"
                  },
                  "email": {
                    "type": "string",
                    "description": "Real email address",
                    "format": "email"
                  },
                  "amount": {
                    "type": "string",
                    "description": "Transaction amount (Unit: ₫ VND) Range: 100,000 – 10,000,000. Must be a multiple of 100",
                    "pattern": ""
                  },
                  "payType": {
                    "type": "string",
                    "description": "Transaction type: QR, PAYMENT_GATEWAY, BANK_TRANSFER, EWALLET",
                    "enum": [
                      "QR",
                      "PAYMENT_GATEWAY",
                      "BANK_TRANSFER",
                      "EWALLET"
                    ]
                  },
                  "inBankCode": {
                    "type": "string",
                    "description": "Payment method. When payType = EWALLET, supports MOMO_VND for MoMo Wallet payment"
                  },
                  "callBackUrl": {
                    "type": "string",
                    "description": "Redirect URL after successful payment",
                    "format": "uri"
                  },
                  "callBackFailUrl": {
                    "type": "string",
                    "description": "Redirect URL after failed payment",
                    "format": "uri"
                  },
                  "notifyUrl": {
                    "type": "string",
                    "description": "Callback URL",
                    "format": "uri"
                  },
                  "currency": {
                    "type": "string",
                    "description": "Currency (default: VND, supported: USD, VND)",
                    "enum": [
                      "USD",
                      "VND"
                    ]
                  },
                  "subject": {
                    "type": "string",
                    "description": "Payment note (transaction title, product name, payment reason)"
                  },
                  "body": {
                    "type": "string",
                    "description": "Detailed note"
                  },
                  "partnerUserId": {
                    "type": "string",
                    "description": "User unique identifier (e.g., userId). Used by risk control, must be valid. Format: numbers, letters, or common symbols -~!@#$%&*()_.",
                    "pattern": "^[A-Za-z0-9\\-~!@#$%&*()_]+$"
                  },
                  "sign": {
                    "type": "string",
                    "description": "Signature"
                  }
                },
                "required": [
                  "appId",
                  "orderId",
                  "name",
                  "phone",
                  "email",
                  "amount",
                  "payType",
                  "callBackUrl",
                  "callBackFailUrl",
                  "partnerUserId",
                  "sign"
                ]
              },
              "examples": {}
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "1: Normal, 0: Exception"
                    },
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "msg": {
                      "type": "string",
                      "description": "Error description"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "Merchant order ID (must be unique)"
                        },
                        "orderNo": {
                          "type": "string",
                          "description": "Platform order ID"
                        },
                        "payUrl": {
                          "type": "string",
                          "description": "Returned payment address, or sometimes a guide/details"
                        },
                        "bankNo": {
                          "type": "string",
                          "description": "Receiving account number (BANK_TRANSFER)"
                        },
                        "bankCode": {
                          "type": "string",
                          "description": "Receiving bank"
                        },
                        "bankUserName": {
                          "type": "string",
                          "description": "Recipient name (BANK_TRANSFER)"
                        },
                        "qrCode": {
                          "type": "string",
                          "description": "QR code content — can be used to generate a QR code (for payType=QR)"
                        },
                        "sign": {
                          "type": "string",
                          "description": "Signature"
                        }
                      },
                      "additionalProperties": true,
                      "description": ""
                    }
                  },
                  "additionalProperties": true
                }
              }
            }
          }
        },
        "security": []
      }
    },
    "/vnd/collect/query": {
      "post": {
        "summary": "VND Collection Query",
        "deprecated": false,
        "description": "查询代收订单\n当\"payType=PAYMENT_GATEWAY\" 时同步返回orderNo可以直接查询\n其他支付方式异步通知后，通过orderNo查询二次确认状态",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "appId": {
                    "type": "integer",
                    "description": "Business ID (obtained from backend, must match the currency in the URL)"
                  },
                  "orderId": {
                    "type": "string",
                    "description": "Merchant order ID"
                  },
                  "orderNo": {
                    "type": "string",
                    "description": "Platform order ID (faster response)"
                  },
                  "sign": {
                    "type": "string",
                    "description": "Signature"
                  }
                },
                "required": [
                  "appId",
                  "orderId",
                  "sign"
                ]
              },
              "examples": {}
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "1: Normal, 0: Exception",
                      "default": ""
                    },
                    "error": {
                      "type": "string",
                      "description": "Error code",
                      "default": ""
                    },
                    "msg": {
                      "type": "string",
                      "description": "Error description",
                      "default": ""
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "Merchant order ID (must be unique)",
                          "default": ""
                        },
                        "orderNo": {
                          "type": "string",
                          "description": "Platform order ID",
                          "default": ""
                        },
                        "amount": {
                          "type": "string",
                          "description": "Transaction amount",
                          "default": ""
                        },
                        "actualAmount": {
                          "type": "string",
                          "description": "Amount received",
                          "default": ""
                        },
                        "fee": {
                          "type": "string",
                          "description": "Fee",
                          "default": ""
                        },
                        "status": {
                          "type": "integer",
                          "description": "Order status (0 Not Started, 1 Processing, 2 Disbursement Success (final), 3 Disbursement Failed (final), -1 Exception Pending Confirmation)",
                          "default": 0
                        },
                        "payTime": {
                          "type": "string",
                          "description": "Payment success time (present when status=2) (Vietnam Time), format: yyyy-MM-dd HH:mm:ss",
                          "default": ""
                        },
                        "errorMsg": {
                          "type": "string",
                          "description": "Payment failure reason (presnet when status=3)",
                          "default": ""
                        },
                        "sign": {
                          "type": "string",
                          "description": "Signature",
                          "default": ""
                        }
                      },
                      "additionalProperties": false,
                      "default": {}
                    }
                  },
                  "additionalProperties": false
                }
              }
            }
          }
        },
        "security": []
      }
    },
