    "/krw/collect/apply": {
      "post": {
        "summary": "KRW Collection Application",
        "deprecated": false,
        "description": "appId需使用韩元对应的，用户支付成功后增加韩元余额",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "appId": {
                    "type": "integer",
                    "description": "Business ID (obtained from backend, must pass corresponding business ID based on currency in URL)"
                  },
                  "orderId": {
                    "type": "string",
                    "description": "Merchant order number",
                    "maxLength": 48
                  },
                  "name": {
                    "type": "string",
                    "description": "User name, recommended to use real name, format: firstName and lastName separated by space, example: Donald John Trump"
                  },
                  "phone": {
                    "type": "string",
                    "description": "Phone number"
                  },
                  "email": {
                    "type": "string",
                    "description": "Email address",
                    "format": "email"
                  },
                  "amount": {
                    "type": "string",
                    "description": "Transaction amount (unit: ₩, accurate to two decimal places; do not add punctuation, e.g., \",\")",
                    "pattern": "^\\d+\\.\\d{2}$"
                  },
                  "payType": {
                    "type": "string",
                    "description": ""
                  },
                  "inBankCode": {
                    "type": "string",
                    "description": ""
                  },
                  "callBackUrl": {
                    "type": "string",
                    "description": "URL to redirect after successful payment",
                    "format": "uri"
                  },
                  "callBackFailUrl": {
                    "type": "string",
                    "description": "URL to redirect after failed payment",
                    "format": "uri"
                  },
                  "notifyUrl": {
                    "type": "string",
                    "description": "Callback URL",
                    "format": "uri"
                  },
                  "subject": {
                    "type": "string",
                    "description": "Payment remark"
                  },
                  "country": {
                    "type": "string",
                    "description": "Cashier mode requires this parameter, please pass: 410"
                  },
                  "body": {
                    "type": "string",
                    "description": "Remark details"
                  },
                  "partnerUserId": {
                    "type": "string",
                    "description": "Unique user identifier (e.g., userId), used for risk control, must be real and valid, otherwise it will affect transactions. Format requirements: digits, uppercase and lowercase letters or common symbols -~!@#$%&*()_.",
                    "pattern": "^[A-Za-z0-9\\-~!@#$%&*()_]+$"
                  },
                  "sign": {
                    "type": "string",
                    "description": "Signature"
                  }
                },
                "required": [
                  "appId",
                  "orderId",
                  "name",
                  "phone",
                  "email",
                  "amount",
                  "payType",
                  "inBankCode",
                  "callBackUrl",
                  "callBackFailUrl",
                  "partnerUserId",
                  "sign"
                ]
              },
              "examples": {}
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "1: Normal, 0: Exception"
                    },
                    "error": {
                      "type": "string",
                      "description": "Error code"
                    },
                    "msg": {
                      "type": "string",
                      "description": "Error description"
                    },
                    "data": {
                      "type": "object",
                      "description": "",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "Merchant order number (must be unique)"
                        },
                        "orderNo": {
                          "type": "string",
                          "description": "Platform order number"
                        },
                        "payUrl": {
                          "type": "string",
                          "description": "Payment link"
                        },
                        "sign": {
                          "type": "string",
                          "description": "Signature"
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                }
              }
            }
          }
        },
        "security": []
