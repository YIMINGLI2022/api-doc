                    "data": {
                      "type": "object",
                      "description": "",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "Merchant order number (must be unique)"
                        },
                        "orderNo": {
                          "type": "string",
                          "description": "Platform order number"
                        },
                        "amount": {
                          "type": "string",
                          "description": "Transaction amount"
                        },
                        "actualAmount": {
                          "type": "string",
                          "description": "Received amount"
                        },
                        "fee": {
                          "type": "string",
                          "description": "Transaction fee"
                        },
                        "status": {
                          "type": "integer",
                          "description": "Status (0 Not Started, 1 In Progress, 2 Success (final), 3 Failed (final), -1 Exception Pending Confirmation)"
                        },
                        "payTime": {
                          "type": "string",
                          "description": "Payment success time (when status=2), format: yyyy-MM-dd HH:mm:ss (Egypt Time)"
                        },
                        "errorMsg": {
                          "type": "string",
                          "description": "Payment failure reason (when status=3)"
                        },
                        "sign": {
                          "type": "string",
                          "description": "Signature"
                        }
                      },
                      "additionalProperties": true
                    }
                  },
                  "additionalProperties": true
                }
              }
            },
            "headers": {}
          }
