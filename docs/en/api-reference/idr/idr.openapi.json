                      "type": "string",
                      "description": "1: Normal, 0: Exception",
                      "default": "1"
                    },
                    "error": {
                      "type": "string",
                      "description": "Error code",
                      "default": "00000000"
                    },
                    "msg": {
                      "type": "string",
                      "description": "Error description",
                      "default": ""
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "Merchant order ID (must be unique)"
