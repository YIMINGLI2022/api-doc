  "tags": [],
  "paths": {
    "/inr/collect/apply": {
      "post": {
        "summary": "INR Collection Application",
        "deprecated": false,
        "description": "",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "appId": {
                    "type": "integer",
                    "description": "Business ID (retrieved from backend, must correspond to the currency in URL)"
                  },
                  "orderId": {
                    "type": "string",
                    "description": "Merchant order number (must be unique, max length 48)",
                    "maxLength": 48
                  },
                  "name": {
                    "type": "string",
                    "description": "Name (Name can only contain letters, no numbers or special characters)",
                    "pattern": "^[A-Za-z\\s]+$"
                  },
                  "phone": {
                    "type": "string",
                    "description": "Phone number (mobile number must be 10 digits, starting with 6-9)",
                    "pattern": "^[6-9]\\d{9}$"
                  },
                  "email": {
                    "type": "string",
                    "description": "Email address (ending in @gmail.com; a name + number combination is recommended as the email prefix)",
                    "pattern": "^[A-Za-z0-9._%+-]+@gmail\\.com$"
                  },
                  "amount": {
                    "type": "string",
                    "description": "Transaction amount (unit: INR, decimals not supported)",
                    "pattern": "^[1-9]\\d*$"
                  },
                  "payType": {
                    "type": "string",
                    "description": "Payment method: `PAYMENT_GATEWAY`",
                    "pattern": "^PAYMENT_GATEWAY$"
                  },
                  "inBankCode": {
                    "type": "string",
                    "description": "UPI",
                    "pattern": "^UPI$"
                  },
                  "callBackUrl": {
                    "type": "string",
                    "description": "Redirect URL after successful payment",
                    "format": "uri"
                  },
                  "callBackFailUrl": {
                    "type": "string",
                    "description": "Redirect URL after failed payment",
                    "format": "uri"
                  },
                  "notifyUrl": {
                    "type": "string",
                    "description": "Callback URL",
                    "format": "uri"
                  },
                  "subject": {
                    "type": "string",
                    "description": "Payment note (transaction title, product name, payment reason, etc.)"
                  },
                  "body": {
                    "type": "string",
                    "description": "Additional remark details"
                  },
                  "partnerUserId": {
                    "type": "string",
                    "description": "Unique user identifier (e.g. userId). Used for risk control, must be valid, otherwise it will affect the transaction. Allowed characters: numbers, letters, or common symbols `-~!@#$%&*()_`.",
                    "pattern": "^[A-Za-z0-9\\-~!@#$%&*()_]+$"
                  },
                  "sign": {
                    "type": "string",
                    "description": "Signature"
                  }
                },
                "required": [
                  "appId",
                  "orderId",
                  "name",
                  "phone",
                  "email",
                  "amount",
                  "payType",
                  "inBankCode",
                  "callBackUrl",
                  "callBackFailUrl",
                  "partnerUserId",
                  "sign"
                ]
              },
              "examples": {}
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "1: Normal, 0: Exception",
                      "default": "1"
                    },
                    "error": {
                      "type": "string",
                      "description": "Error code",
                      "default": "00000000"
                    },
                    "msg": {
                      "type": "string",
                      "description": "Error description",
                      "default": ""
                    },
                    "data": {
                      "type": "object",
                      "description": "",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "Merchant Order ID (must be unique)"
                        },
                        "orderNo": {
                          "type": "string",
                          "description": "Platform Order ID"
                        },
                        "payUrl": {
                          "type": "string",
                          "description": "Payment URL"
                        },
                        "bankCode": {
                          "type": "string",
                          "description": ""
                        },
                        "bankNo": {
                          "type": "string",
                          "description": ""
                        },
                        "sign": {
                          "type": "string",
                          "description": "Signature"
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                }
              }
            }
          }
        },
        "security": []
      }
    },
