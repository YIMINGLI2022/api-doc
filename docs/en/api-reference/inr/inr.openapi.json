                        "fee": {
                          "type": "string",
                          "description": "Fee",
                          "default": ""
                        },
                        "status": {
                          "type": "integer",
                          "description": "Order Status (0 = Not Started, 1 = Processing, 2 = Disbursement Successful (final), 3 = Disbursement Failed (final), -1 = Exception Pending Confirmation)",
                          "default": 0
                        },
                        "payTime": {
                          "type": "string",
                          "description": "Disbursement Success Time (available when status = 2), format: yyyy-MM-dd HH:mm:ss",
                          "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$",
                          "default": ""
                        },
                        "errorMsg": {
                          "type": "string",
                          "description": "Disbursement Failure Reason (available when status = 3)",
                          "default": ""
                        },
                        "sign": {
                          "type": "string",
                          "description": "Signature",
                          "default": ""
