  "paths": {
    "/usdt/collect/apply": {
      "post": {
        "summary": "USDT Collection Application",
        "deprecated": false,
        "description": "",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "appId": {
                    "type": "integer",
                    "description": "Business ID (obtained in the backend; must correspond to the currency in the URL)"
                  },
                  "orderId": {
                    "type": "string",
                    "description": "Merchant order number",
                    "maxLength": 48
                  },
                  "name": {
                    "type": "string",
                    "description": "User name, recommended to use real name, format: include firstName and lastName, separated by space, example: Donald John Trump"
                  },
                  "phone": {
                    "type": "string",
                    "description": "Real mobile number"
                  },
                  "email": {
                    "type": "string",
                    "description": "Real email address",
                    "format": "email"
                  },
                  "amount": {
                    "type": "string",
                    "description": "Transaction amount (prohibited to add punctuation marks such as \",\") Range reference: 0.01-5000000",
                    "pattern": "^\\d+\\.?\\d{0,2}$"
                  },
                  "payType": {
                    "type": "string",
                    "description": "[Payment type](#inBankCode)"
                  },
                  "inBankCode": {
                    "type": "string",
                    "description": "[Payment code](#inBankCode)"
                  },
                  "callBackUrl": {
                    "type": "string",
                    "description": "Redirect URL after successful payment",
                    "format": "uri"
                  },
                  "callBackFailUrl": {
                    "type": "string",
                    "description": "Redirect URL after failed payment",
                    "format": "uri"
                  },
                  "subject": {
                    "type": "string",
                    "description": "Payment note"
                  },
                  "body": {
                    "type": "string",
                    "description": "Note details"
                  },
                  "clientType": {
                    "type": "string",
                    "description": "APP, WEB, WAP, MINIAPP, OTHERS",
                    "enum": [
                      "APP",
                      "WEB",
                      "WAP",
                      "MINIAPP",
                      "OTHERS"
                    ]
                  },
                  "currency": {
                    "type": "string",
                    "description": "Fiat currency. If no currency conversion is required, pass USDT/USDC"
                  },
                  "notifyUrl": {
                    "type": "string",
                    "description": "webhook URL",
                    "format": "uri"
                  },
                  "partnerUserId": {
                    "type": "string",
                    "description": "Unique user identifier (e.g., userId), used for risk control system, must be valid, otherwise it will affect the transaction. Format: digits, letters, or symbols -~!@#$%&*()_.",
                    "pattern": "^\\d+$"
                  },
                  "sign": {
                    "type": "string",
                    "description": "Signature"
                  }
                },
                "required": [
                  "appId",
                  "orderId",
                  "name",
                  "phone",
                  "email",
                  "amount",
                  "payType",
                  "inBankCode",
                  "callBackUrl",
                  "callBackFailUrl",
                  "clientType",
                  "currency",
                  "partnerUserId",
                  "sign"
                ]
              },
              "examples": {}
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "1: Normal, 0: Exception",
                      "default": "1"
                    },
                    "error": {
                      "type": "string",
                      "description": "Error code",
                      "default": "00000000"
                    },
                    "msg": {
                      "type": "string",
                      "description": "Error description",
                      "default": ""
                    },
                    "data": {
                      "type": "object",
                      "description": "",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "Merchant order number (unique)"
                        },
                        "orderNo": {
                          "type": "string",
                          "description": "Platform order number"
                        },
                        "payUrl": {
                          "type": "string",
                          "description": "Payment link"
                        },
                        "exchangeRate": {
                          "type": "string",
                          "description": "Exchange rate"
                        },
                        "orderAmount": {
                          "type": "string",
                          "description": "Converted currency amount"
                        },
                        "amount": {
                          "type": "string",
                          "description": "Transaction amount"
                        },
                        "bankNo": {
                          "type": "string",
                          "description": "Chain address"
                        },
                        "sign": {
                          "type": "string",
                          "description": "Signature"
                        }
                      },
                      "additionalProperties": false,
                      "default": {}
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    },
