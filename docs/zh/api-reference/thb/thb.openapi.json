                    },
                    "msg": {
                      "type": "string",
                      "description": "响应消息"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "商户订单号(必须保证唯一性)"
                        },
                        "orderNo": {
                          "type": "string",
