                              },
                              "startTime": {
                                "type": "string",
                                "description": "订阅扣款周期-起始时间"
                              },
                              "endTime": {
                                "type": "string",
                                "description": "订阅扣款周期-结束时间"
                              }
                            },
                            "required": [
                              "deductNo",
