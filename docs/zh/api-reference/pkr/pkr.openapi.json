                    "status": {
                      "type": "string",
                      "description": "响应状态码",
                      "default": "1"
                    },
                    "error": {
                      "type": "string",
                      "description": "错误码",
                      "default": "00000000"
                    },
                    "msg": {
                      "type": "string",
                      "description": "响应消息",
                      "default": ""
                    },
                    "data": {
                      "type": "object",
                      "description": "响应数据",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "商户订单号(必须保证唯一性)"
                        },
                        "orderNo": {
                          "type": "string",
                          "description": "平台订单号"
                        },
                        "amount": {
                          "type": "string",
                          "description": "交易金额"
                        },
                        "fee": {
                          "type": "string",
                          "description": "手续费"
                        },
                        "status": {
                          "type": "integer",
                          "description": "状态(0未开始，1支付中，2成功（终态），3失败（终态）, -1异常待确认)",
                          "enum": [
                            0,
                            1,
                            2,
                            3,
                            -1
                          ]
                        },
                        "payTime": {
                          "type": "string",
                          "description": "支付成功时间（当status=2时有值）(巴基斯坦时间), 格式: yyyy-MM-dd HH:mm:ss",
                          "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$"
                        },
                        "errorMsg": {
                          "type": "string",
                          "description": "支付失败原因（当status=3时有值）"
                        },
                        "sign": {
                          "type": "string",
                          "description": "签名"
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "headers": {}
          }
