                      "default": "00000000"
                    },
                    "msg": {
                      "type": "string",
                      "description": "消息",
                      "default": ""
                    },
                    "data": {
                      "type": "object",
                      "description": "数据对象",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "商户订单号(必须保证唯一性)",
                          "default": null
