              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "响应状态码"
                    },
                    "error": {
                      "type": "string",
                      "description": "错误码"
                    },
                    "msg": {
                      "type": "string",
                      "description": "响应消息"
                    },
                    "data": {
                      "type": "object",
                      "description": "响应数据对象",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "商户订单号(必须保证唯一性)"
                        },
                        "orderNo": {
                          "type": "string",
                          "description": "平台订单号"
                        },
                        "amount": {
                          "type": "string",
                          "description": "交易金额"
                        },
                        "actualAmount": {
                          "type": "string",
                          "description": "收到金额"
                        },
                        "fee": {
                          "type": "string",
                          "description": "手续费"
                        },
                        "status": {
                          "type": "integer",
                          "description": "状态(0未开始，1支付中，2成功（终态），3失败（终态）, -1异常待确认)"
                        },
                        "payTime": {
                          "type": "string",
                          "description": "支付成功时间（当status=2,4,5时有值）(印尼时间), 格式: yyyy-MM-dd HH:mm:ss"
                        },
                        "errorMsg": {
                          "type": "string",
                          "description": "失败原因（当status=3时有值）"
                        },
                        "sign": {
                          "type": "string",
                          "description": "签名"
                        }
                      },
                      "additionalProperties": true
                    }
                  },
                  "additionalProperties": true
                }
              }
            }
          }
        },
        "security": []
      }
    },
