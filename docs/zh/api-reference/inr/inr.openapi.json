{
  "openapi": "3.0.1",
  "info": {
    "title": "默认模块",
    "description": "",
    "version": "1.0.0"
  },
  "tags": [],
  "paths": {
    "/inr/collect/apply": {
      "post": {
        "summary": "代收申请",
        "deprecated": false,
        "description": "",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "appId": {
                    "type": "integer",
                    "description": "业务ID（后台获取，需要根据URL中的币种传递对应的业务ID）"
                  },
                  "orderId": {
                    "type": "string",
                    "description": "商户订单号(必须保证唯一性，长度不超过48)",
                    "maxLength": 48
                  },
                  "name": {
                    "type": "string",
                    "description": "姓名(姓名只能字母，不能包含数字和特殊字符)",
                    "pattern": "^[A-Za-z\\s]+$"
                  },
                  "phone": {
                    "type": "string",
                    "description": "电话号码(手机号以6-9开头的10位数字)",
                    "pattern": "^[6-9]\\d{9}$"
                  },
                  "email": {
                    "type": "string",
                    "description": "电子邮件地址(邮箱以@gmail.com结尾,邮箱前缀建议考虑姓名+数字组合)",
                    "pattern": "^[A-Za-z0-9._%+-]+@gmail\\.com$"
                  },
                  "amount": {
                    "type": "string",
                    "description": "交易金额(单位：INR，不支持小数）",
                    "pattern": "^[1-9]\\d*$"
                  },
                  "payType": {
                    "type": "string",
                    "description": "支付方式 PAYMENT_GATEWAY",
                    "pattern": "^PAYMENT_GATEWAY$"
                  },
                  "inBankCode": {
                    "type": "string",
                    "description": "UPI",
                    "pattern": "^UPI$"
                  },
                  "callBackUrl": {
                    "type": "string",
                    "description": "用户支付成功后跳转地址",
                    "format": "uri"
                  },
                  "callBackFailUrl": {
                    "type": "string",
                    "description": "用户支付失败后跳转地址",
                    "format": "uri"
                  },
                  "notifyUrl": {
                    "type": "string",
                    "description": "回调地址",
                    "format": "uri"
                  },
                  "subject": {
                    "type": "string",
                    "description": "支付备注"
                  },
                  "body": {
                    "type": "string",
                    "description": "备注详情"
                  },
                  "partnerUserId": {
                    "type": "string",
                    "description": "用户唯一标识（如用户ID userId），用于风控系统，必须真实有效，否则会影响交易。 格式要求：数字、大小写字母或常用符号-~!@#$%&*()_。",
                    "pattern": "^[A-Za-z0-9\\-~!@#$%&*()_]+$"
                  },
                  "sign": {
                    "type": "string",
                    "description": "签名"
                  }
                },
                "required": [
                  "appId",
                  "orderId",
                  "name",
                  "phone",
                  "email",
                  "amount",
                  "payType",
                  "inBankCode",
                  "callBackUrl",
                  "callBackFailUrl",
                  "partnerUserId",
                  "sign"
                ]
              },
              "examples": {}
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "状态码",
                      "default": "1"
                    },
                    "error": {
                      "type": "string",
                      "description": "错误码",
                      "default": "00000000"
                    },
                    "msg": {
                      "type": "string",
                      "description": "返回信息",
                      "default": ""
                    },
                    "data": {
                      "type": "object",
                      "description": "返回数据",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "商户订单号(必须保证唯一性)"
                        },
                        "orderNo": {
                          "type": "string",
                          "description": "平台订单号"
                        },
                        "payUrl": {
                          "type": "string",
                          "description": "支付链接"
                        },
                        "bankCode": {
                          "type": "string",
                          "description": "支付编码"
                        },
                        "bankNo": {
                          "type": "string",
                          "description": "支付账号(可能为空)"
                        },
                        "sign": {
                          "type": "string",
                          "description": "签名"
                        }
                      },
                      "additionalProperties": false
                    }
                  },
                  "additionalProperties": false
                }
              }
            }
          }
        },
        "security": []
      }
    },
    "/inr/collect/query": {
      "post": {
        "summary": "代收查询",
        "deprecated": false,
        "description": "",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "appId": {
                    "type": "integer",
                    "description": "业务ID（后台获取，需要根据URL中的币种传递对应的业务ID）"
                  },
                  "orderId": {
                    "type": "string",
                    "description": "商户订单号"
                  },
                  "orderNo": {
                    "type": "string",
                    "description": "平台订单号（响应快）"
                  },
                  "sign": {
                    "type": "string",
                    "description": "签名"
                  }
                },
                "required": [
                  "appId",
                  "orderId",
                  "sign"
                ]
              },
              "examples": {}
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "description": "响应状态标识",
                      "default": ""
                    },
                    "error": {
                      "type": "string",
                      "description": "错误码",
                      "default": ""
                    },
                    "msg": {
                      "type": "string",
                      "description": "响应消息",
                      "default": ""
                    },
                    "data": {
                      "type": "object",
                      "description": "业务数据",
                      "properties": {
                        "orderId": {
                          "type": "string",
                          "description": "商户订单号(必须保证唯一性)",
                          "default": ""
                        },
                        "orderNo": {
                          "type": "string",
                          "description": "平台订单号",
                          "default": ""
                        },
                        "amount": {
                          "type": "string",
                          "description": "交易金额",
                          "default": ""
                        },
                        "actualAmount": {
                          "type": "string",
                          "description": "收到金额",
                          "default": ""
                        },
                        "fee": {
                          "type": "string",
                          "description": "手续费",
                          "default": ""
                        },
                        "status": {
                          "type": "integer",
                          "description": "状态(0未开始，1支付中，2成功（终态），3失败（终态），4部分收款（终态），5超额收款（终态）, -1异常待确认)",
                          "default": 0
                        },
                        "payTime": {
                          "type": "string",
                          "description": "支付成功时间（当status=2时有值）, 格式: yyyy-MM-dd HH:mm:ss",
                          "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}$",
                          "default": ""
                        },
                        "errorMsg": {
                          "type": "string",
                          "description": "支付失败原因（当status=3时有值）",
                          "default": ""
                        },
                        "sign": {
                          "type": "string",
                          "description": "签名",
                          "default": ""
                        }
                      },
                      "additionalProperties": false,
                      "default": {}
                    }
                  },
                  "additionalProperties": false
                }
              }
            }
          }
        },
        "security": []
      }
    },
